<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <MslRoot Condition="'$(MslRoot)' == '' and Exists('..\..\ModShardLauncher.dll')">..\..</MslRoot>
    <MslRoot Condition="'$(MslRoot)' == ''">J:\msl</MslRoot>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="ModShardLauncher">
      <HintPath>$(MslRoot)\ModShardLauncher.dll</HintPath>
    </Reference>
    <Reference Include="UndertaleModLib">
      <HintPath>$(MslRoot)\UndertaleModLib.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>
